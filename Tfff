        public class $TypeName$ : Ticket
        {
            public $TypeName$(Passenger passenger, string departure, string destination, decimal price) 
                : base(passenger, departure, destination, price)
            {
            }

            public override Ticket Clone()
            {
                return new $TypeName$(this.Passenger?.Clone(), this.Departure, this.Destination, this.Price);
            }

            public override void ShowInfo()
            {
                Console.WriteLine($"[$TypeName$] {Departure} -> {Destination} | {Price} руб.");
            }
        }
        ]]>
      </Code>
    </Snippet>
  </CodeSnippet>
